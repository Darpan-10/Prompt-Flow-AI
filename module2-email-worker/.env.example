# ── App ──────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_DOMAIN=srmap.edu.in

# ── Gmail OAuth2 (Service Account + Domain-Wide Delegation) ───────────────
# ── Gmail Auth Mode ──────────────────────────────────────────────────────
# "service_account": headless via Domain-Wide Delegation. Requires a
#   Google WORKSPACE admin console — this literally cannot work against
#   a personal @gmail.com account, there's no delegation to grant.
# "oauth_personal": standard OAuth2 consent, works with ANY Gmail account
#   (personal or Workspace), no admin needed. One-time interactive login
#   via `python scripts/gmail_oauth_login.py`, headless after that.
#   Recommended for a demo without college admin access.
GMAIL_AUTH_MODE=oauth_personal

# Only used when GMAIL_AUTH_MODE=service_account:
# Paste the FULL service account JSON as a single-line string
# In production: injected from AWS Secrets Manager at container startup
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GMAIL_DELEGATED_USER=papers@srmap.edu.in

# Only used when GMAIL_AUTH_MODE=oauth_personal — see
# scripts/gmail_oauth_login.py for how these get created:
GMAIL_OAUTH_CLIENT_SECRET_PATH=gmail_oauth_client_secret.json
GMAIL_OAUTH_TOKEN_PATH=gmail_oauth_token.json

# ── Redis ─────────────────────────────────────────────────────────────────
# This is Module 4's shared Redis instance (Module 2 doesn't run its own).
# Local (native, outside Docker): localhost:6380 — Module 4's docker-compose
#   maps container port 6379 to host port 6380 to avoid clashing with
#   Module 1's own separate Redis (which uses the default 6379).
# Local (docker-compose): redis:6379 — the internal container port, reached
#   over promptflow_shared_net.
REDIS_URL=redis://:localdevtoken@localhost:6380
REDIS_DEDUP_TTL_SECONDS=604800

# ── AWS ───────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_INGESTION_BUCKET=promptflow-ingestion-dev
S3_QUARANTINE_BUCKET=promptflow-quarantine-dev

# ── Kafka ─────────────────────────────────────────────────────────────────
# This is Module 4's shared Kafka broker (Module 2 doesn't run its own).
# Local (native, outside Docker): localhost:9093 — Module 4's Kafka
#   advertises a PLAINTEXT_HOST listener specifically for this (see
#   module4-storage/docker-compose.yml's KAFKA_ADVERTISED_LISTENERS).
#   localhost:9092 will NOT work — nothing listens there.
# Local (docker-compose): kafka:29092 — the internal PLAINTEXT listener,
#   reached over promptflow_shared_net.
# AWS MSK: broker.ap-south-1.amazonaws.com:9096 with SASL_SSL
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_TOPIC_INGEST=ingest.raw
KAFKA_TOPIC_DLQ=dlq.ingestion.failed
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_MAX_RETRIES=3

# ── ClamAV ────────────────────────────────────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30

# ── Database ──────────────────────────────────────────────────────────────
# Used only for audit_log writes (Module 4's shared table — see
# app/services/audit.py). This is Module 4's Postgres, not a local one.
# Local (native, outside Docker): localhost:5433 — Module 4 maps its
#   Postgres to host port 5433 to avoid clashing with Module 1's own
#   separate Postgres (which uses the default 5432).
# Local (docker-compose): postgres:5432 — the internal container port.
DATABASE_URL=postgresql://promptflow:secret@localhost:5433/promptflow

# ── Worker ────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
MAX_ATTACHMENT_SIZE_BYTES=52428800
