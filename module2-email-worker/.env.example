# ── App ──────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_DOMAIN=srmap.edu.in

# ── Gmail OAuth2 (Service Account + Domain-Wide Delegation) ───────────────
# Paste the FULL service account JSON as a single-line string
# In production: injected from AWS Secrets Manager at container startup
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GMAIL_DELEGATED_USER=papers@srmap.edu.in

# ── Redis ─────────────────────────────────────────────────────────────────
# Local: redis://:localdevtoken@localhost:6379
# AWS:   rediss://:${AUTH_TOKEN}@${ELASTICACHE_ENDPOINT}:6379
REDIS_URL=redis://:localdevtoken@localhost:6379
REDIS_DEDUP_TTL_SECONDS=604800

# ── AWS ───────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_INGESTION_BUCKET=promptflow-ingestion-dev
S3_QUARANTINE_BUCKET=promptflow-quarantine-dev

# ── Kafka ─────────────────────────────────────────────────────────────────
# Local:  localhost:9092 with PLAINTEXT
# AWS MSK: broker.ap-south-1.amazonaws.com:9096 with SASL_SSL
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGEST=ingest.raw
KAFKA_TOPIC_DLQ=dlq.ingestion.failed
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_MAX_RETRIES=3

# ── ClamAV ────────────────────────────────────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://promptflow:secret@localhost:5432/promptflow

# ── Worker ────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
MAX_ATTACHMENT_SIZE_BYTES=52428800
