# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
WORKER_ID=module4-worker-1

# ── Database ───────────────────────────────────────────────────────────────────
# Local Docker
DATABASE_URL=postgresql+asyncpg://promptflow:secret@localhost:5433/promptflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# AWS RDS (production — set these in ECS task environment)
# DATABASE_URL=postgresql+asyncpg://promptflow:<password>@<rds-endpoint>:5432/promptflow

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_CONSUMER_GROUP=module4-storage-worker
KAFKA_TOPIC_PAPERS_VALIDATED=papers.validated
KAFKA_TOPIC_PAPERS_REVIEW=papers.review
KAFKA_TOPIC_PAPERS_FAILED=papers.failed
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_AUTO_OFFSET_RESET=earliest

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:localdevtoken@localhost:6380
REDIS_PROCESSED_TTL_SECONDS=604800

# ── FastAPI ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8003
API_PREFIX=/api/v1

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_INGESTION_BUCKET=promptflow-ingestion-dev

# ── Search ────────────────────────────────────────────────────────────────────
VECTOR_DIMENSIONS=768
SEARCH_MAX_RESULTS=50
FULLTEXT_LANGUAGE=english
