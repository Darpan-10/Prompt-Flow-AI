# ── App ──────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
WORKER_ID=module5-search-1

# ── Database (READ-ONLY -- same RDS instance as Module 4) ────────────────
# Local Docker default. In AWS, point this at the SAME RDS endpoint
# Module 4 uses, ideally via a read-only DB user if you've created one.
DATABASE_URL=postgresql+asyncpg://promptflow:secret@localhost:5433/promptflow
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── FastAPI ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8005
API_PREFIX=/api/v1

# ── Redis (SHARED with Module 4 -- key-prefixed: search:*, facets:*) ─────
REDIS_URL=redis://:localdevtoken@localhost:6380
REDIS_SEARCH_CACHE_TTL=300
REDIS_FACETS_CACHE_TTL=3600
REDIS_PUBSUB_CHANNEL=search_invalidate

# ── Search Configuration ──────────────────────────────────────────────────
VECTOR_DIMENSIONS=768
EMBEDDING_MODEL=all-mpnet-base-v2
SEARCH_RESULTS_MAX=100
SEARCH_RESULTS_DEFAULT=20
QUERY_MAX_LENGTH=200
RRF_K=60

# ── JWT / Auth (from Module 1) ────────────────────────────────────────────
JWT_ALGORITHM=RS256
JWT_ISSUER=https://auth.srmap.edu.in
JWT_AUDIENCE=promptflow-api

# Set to "true" for LOCAL TESTING ONLY -- skips signature verification so
# you can hand-craft test JWTs without Module 1's private key.
# MUST be "false" in any deployed environment.
SKIP_JWT_VALIDATION=true

# RS256 public key from Module 1, PEM format, single line with \n escapes.
# Only required when SKIP_JWT_VALIDATION=false.
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
