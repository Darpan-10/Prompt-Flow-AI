# -- App ------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# -- Database (READ-WRITE -- same shared Postgres as Module 4) -----------
DATABASE_URL=postgresql+asyncpg://promptflow:secret@localhost:5433/promptflow
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# -- FastAPI ----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8006
API_PREFIX=/api/v1

# -- S3 (report storage) -----------------------------------------------------
AWS_REGION=ap-south-1
S3_REPORTS_BUCKET=promptflow-reports-dev
S3_PRESIGNED_URL_EXPIRY_SECONDS=3600

# Local dev: point at the MinIO service in docker-compose.yml instead of
# real AWS S3 (see SETUP.md). Leave blank to use real AWS.
AWS_ENDPOINT_URL=http://localhost:9100
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# -- JWT / Auth (from Module 1) ----------------------------------------------
JWT_ALGORITHM=RS256
JWT_ISSUER=https://auth.srmap.edu.in
JWT_AUDIENCE=promptflow-api

# Set to "true" for LOCAL TESTING ONLY -- skips signature verification so
# you can hand-craft test JWTs without Module 1's private key.
# MUST be "false" in any deployed environment.
SKIP_JWT_VALIDATION=true

# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# -- Report generation --------------------------------------------------------
REPORT_TEMPLATE_DIR=app/templates/reports
