# ── App ──────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
WORKER_ID=module3-worker-1

# ── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_CONSUMER_GROUP=module3-ai-extraction
KAFKA_TOPIC_INGEST_RAW=ingest.raw
KAFKA_TOPIC_PAPERS_VALIDATED=papers.validated
KAFKA_TOPIC_PAPERS_REVIEW=papers.review
KAFKA_TOPIC_PAPERS_FAILED=papers.failed
KAFKA_TOPIC_DLQ=dlq.ingestion.failed
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ── Redis (idempotency) ───────────────────────────────────────────────────
REDIS_URL=redis://:localdevtoken@localhost:6380
REDIS_PROCESSED_TTL_SECONDS=604800

# ── AWS ───────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_INGESTION_BUCKET=promptflow-ingestion-dev

# ── AWS Bedrock (Tier 4 LLM) ──────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MAX_TOKENS=1500
LLM_CONFIDENCE_THRESHOLD=0.70
LLM_CONFIDENCE_CAP=0.90

# ── CrossRef API (Tier 2) ────────────────────────────────────────────────
CROSSREF_API_URL=https://api.crossref.org/works
CROSSREF_TIMEOUT_SECONDS=10
CROSSREF_MAILTO=promptflow@srmap.edu.in

# ── Directory API (Faculty Lookup) ───────────────────────────────────────
# Real: Module 1's directory endpoint (M2M-authenticated) — see
#   module1-auth/app/routes/directory.py
# Mock: http://localhost:8080 (mock-directory docker service) — isolated
#   testing only, never returns a real faculty_id UUID
DIRECTORY_API_URL=http://localhost:8000
DIRECTORY_TIMEOUT_SECONDS=3
DIRECTORY_MAX_RETRIES=2

# Module 1 issues the M2M token used to call the directory API.
# Provision with: cd module1-auth && python scripts/create_service_account.py module3-ai-worker "Module 3 AI Worker"
AUTH_SERVICE_URL=http://localhost:8000
M2M_CLIENT_ID=module3-ai-worker
M2M_CLIENT_SECRET=

# ── Routing ───────────────────────────────────────────────────────────────
DEFAULT_CONFIDENCE_THRESHOLD=0.75

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://promptflow:secret@localhost:5433/promptflow
