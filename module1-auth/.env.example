# App
APP_ENV=development
# CORS: allow_credentials=True (refresh_token cookie) means this can NOT be "*"
# per the CORS spec. List every origin a browser will call this API from.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://localhost:8000,http://localhost:8001,http://localhost:8002,http://localhost:8003

# Database
DATABASE_URL=postgresql://promptflow:secret@localhost:5432/promptflow

# Redis
REDIS_URL=redis://localhost:6379

# JWT Keys (generate with: python scripts/generate_keys.py)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
JWT_ISSUER=https://auth.promptflow.ai
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Domain allowlist
ALLOWED_EMAIL_DOMAINS=srmap.edu.in

# AWS Cognito (optional - for production)
COGNITO_REGION=ap-south-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=

# Rate Limiting
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=60
